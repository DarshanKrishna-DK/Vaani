# Vaani backend configuration
# All values are OPTIONAL - the MVP runs fully without any of them.

# ---- AI (Groq free tier) ----
# Get a free key at https://console.groq.com/keys
# Without this, the agent uses a deterministic fallback planner (still fully
# functional; only the natural-language phrasing is simpler).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Server ----
PORT=5050

# ---- Database (Supabase free tier) ----
# Optional. Without these, Vaani uses an in-memory store seeded with demo data.
# To use Supabase, create a project, run docs/SUPABASE_SCHEMA.sql, then set:
SUPABASE_URL=
SUPABASE_KEY=
